rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to all for the public dashboard
    match /employees/{employeeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default allow read, restrict write
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
